<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{ full_name or 'Candidate' }} — Resume</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <header class="resume-header">
      <h1>{{ full_name or 'Candidate' }}</h1>
      {% if contact_line %}
      <p class="contact">{{ contact_line }}</p>
      {% endif %}
    </header>

    {% if summary %}
    <section class="summary">
      <h2>Summary</h2>
      <p>{{ summary }}</p>
    </section>
    {% endif %}

    {% if skills %}
    <section class="skills">
      <h2>Skills</h2>
      <ul class="skill-list">
        {% for s in skills %}<li>{{ s }}</li>{% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if experience %}
    <section class="experience">
      <h2>Experience</h2>
      {% for job in experience %}
      <article class="job">
        <div class="job-head">
          <h3>{{ job.title }} <span class="at">at</span> {{ job.company }}</h3>
          <p class="duration">{{ job.duration }}</p>
        </div>
        {% if job.bullet_points %}
        <ul class="bullets">
          {% for b in job.bullet_points %}<li>{{ b }}</li>{% endfor %}
        </ul>
        {% endif %}
      </article>
      {% endfor %}
    </section>
    {% endif %}

    {% if education %}
    <section class="education">
      <h2>Education</h2>
      <ul>
        {% for e in education %}<li>{{ e }}</li>{% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if certifications %}
    <section class="certs">
      <h2>Certifications</h2>
      <ul>
        {% for c in certifications %}<li>{{ c }}</li>{% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if contact_info_redacted %}
    <footer class="redacted-note"><em>Contact information redacted for privacy.</em></footer>
    {% endif %}
  </body>
</html>
