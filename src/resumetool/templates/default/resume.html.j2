<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>{{ full_name or 'Candidate' }} — Resume</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <h1>{{ full_name or 'Candidate' }}</h1>
    {% if summary %}<p class="summary">{{ summary }}</p>{% endif %}
    {% if skills %}
    <h2>Skills</h2>
    <ul>
      {% for s in skills %}<li>{{ s }}</li>{% endfor %}
    </ul>
    {% endif %}
  </body>
</html>

